#------------------------------------------------------------------------------
# Meta ads attribution XMP schema — copied verbatim from the scf-metadata
# Electron app (v0.11.9, Fuerza Studio, MIT). Defines the XMP-Attrib namespace
# `http://ns.attribution.com/ads/1.0/` used by Meta for ad delivery attribution.
#
# DO NOT EDIT without updating src/lib/metadata-stamp accordingly. The server
# stamp route passes this file via `et.write(path, tags, ['-config', <path>])`
# so exiftool knows how to serialize the Attrib:Ads struct.
#
# The `Ads` Seq is an ordered array of records. Each record carries FbId,
# ExtId, Data, Created (+ optional TouchType, Mark). The reference app reads
# existing entries and appends a new one on each stamp — the same semantics
# this project replicates.
#------------------------------------------------------------------------------
%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::Main' => {
        Attrib => { # <-- must be the same as the NAMESPACE prefix
            SubDirectory => {
                TagTable => 'Image::ExifTool::UserDefined::Attrib',
                # (see the definition of this table below)
            },
        },
    },
);

%Image::ExifTool::UserDefined::Attrib = (
    GROUPS        => { 0 => 'XMP', 1 => 'XMP-Attrib', 2 => 'Image' },
    NAMESPACE     => { 'Attrib' => 'http://ns.attribution.com/ads/1.0/' },
    WRITABLE      => 'string',
    Ads   => {
      Struct => {
        FbId => {Writable => 'integer'},
        ExtId => {},
        Data => {},
        Created => {Writable => 'date'},
        TouchType => {Writable => 'integer'},
        Mark  => {Writable => 'string'},
      },
      List => 'Seq',
      Name => 'Attrib',
    },
);

1;  #end
